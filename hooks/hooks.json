    "UserPromptSubmit": [
      {
        "matcher": "",
        "hook_type": "command",
        "command": "npx adit-hook prompt-submit",
        "timeout": 5000
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hook_type": "command",

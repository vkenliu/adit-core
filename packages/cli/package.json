{
  "name": "@varveai/adit-cli",
  "version": "0.2.1",
  "description": "AI Development Intent Tracker — Transparent Time Machine for your codebase",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "bin": {
    "adit": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vkenliu/adit-core"
  },
  "homepage": "https://github.com/vkenliu/adit-core",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@varveai/adit-cloud": "workspace:*",
    "@varveai/adit-core": "workspace:*",
    "@varveai/adit-engine": "workspace:*",
    "@varveai/adit-hooks": "workspace:*",
    "@varveai/adit-plans": "workspace:*",
    "commander": "^13.0.0",
    "ink": "^5.2.1",
    "ink-spinner": "^5.0.0",
    "picocolors": "^1.1.1",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.28",
    "typescript": "^5.7.2"
  }
}
